import json
import glob
directory = 'data'
 
content = []
for filename in glob.iglob(f'{directory}/*'): 
    with open(filename, 'r') as json_file:
        json_list = list(json_file)
    for json_str in tqdm(json_list):
        result = json.loads(json_str)
        #print(result.keys())
        content.append([filename.split('.')[0],result['date'],result['renderedContent'],result['replyCount'],\
                      result['retweetCount'],result['likeCount'],result['lang'],\
                      result['source'],result['username'],result['hashtags']])
        
df = pd.DataFrame(content, columns = ['stock', 'date','renderedContent','replyCount','retweetCount','likeCount',\
                                  'lang','source','username','hashtags'])
