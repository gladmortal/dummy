import dash
from dash import dcc, html
from dash.dependencies import Input, Output, State
import pandas as pd
import random

app = dash.Dash(__name__)

# Sample stock data (you should replace this with your actual data)
stocks = pd.DataFrame({
    'Asset Name': ['AAPL', 'GOOGL', 'MSFT'],
    'Dividend Announced': [random.choice([True, False]) for _ in range(3)],
    'Split Announced': [random.choice([True, False]) for _ in range(3)]
})

app.layout = html.Div([
    # Include Bootstrap CSS via CDN
    html.Link(
        rel='stylesheet',
        href='https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css'
    ),

    html.Nav(
        html.H1("Stock Validation Dashboard", className='display-4 mx-auto mt-3 mb-4'),
        className='navbar navbar-expand-lg navbar-light bg-light'
    ),

    html.Div([
        dcc.Dropdown(
            id='asset-dropdown',
            options=[{'label': asset, 'value': asset} for asset in stocks['Asset Name']],
            value=stocks['Asset Name'][0],
            className='form-control'
        ),

        dcc.Dropdown(
            id='filter-dropdown',
            options=[
                {'label': 'Dividend Announced', 'value': 'dividend'},
                {'label': 'Split Announced', 'value': 'split'}
            ],
            multi=True,
            className='form-control'
        ),
    ], className='form-row mb-3 mx-auto', style={'max-width': '800px'}),

    dcc.Graph(id='stock-graph', className='mx-auto', style={'max-width': '800px'}),

    html.Div([
        dcc.Textarea(
            id='feedback',
            placeholder="Provide feedback here...",
            className='form-control'
        ),
        html.Button('Submit Feedback', id='submit-feedback', className='btn btn-primary mt-2'),
    ], className='mx-auto', style={'max-width': '800px'}),

    # Feedback section for each stock
    html.Div(id='stock-feedback-section', className='mt-3 mx-auto', style={'max-width': '800px'}),
])

@app.callback(
    Output('stock-graph', 'figure'),
    Input('asset-dropdown', 'value'),
    Input('filter-dropdown', 'value')
)
def update_graph(selected_asset, selected_filters):
    # Filter the data based on user selections
    filtered_stocks = stocks[stocks['Asset Name'] == selected_asset]
    if 'dividend' in selected_filters:
        filtered_stocks = filtered_stocks[filtered_stocks['Dividend Announced'] == True]
    if 'split' in selected_filters:
        filtered_stocks = filtered_stocks[filtered_stocks['Split Announced'] == True]

    # Generate a simple graph (you can replace this with your actual plotting code)
    return {
        'data': [{'x': [1, 2, 3], 'y': [random.uniform(100, 200) for _ in range(3)], 'type': 'line', 'name': 'Stock Data'}],
        'layout': {'title': f'Stock Data for {selected_asset}'}
    }

@app.callback(
    Output('stock-feedback-section', 'children'),
    Input('asset-dropdown', 'value')
)
def update_feedback_section(selected_asset):
    # Create a dynamic feedback section for each stock
    feedback_section = []
    for asset in stocks['Asset Name']:
        if asset == selected_asset:
            feedback_section.append(html.Div([
                html.H5(f'Feedback for {selected_asset}:', className='mb-2'),
                html.P("Add your feedback here:", className='text-muted'),
                dcc.Textarea(
                    id='feedback-' + asset,
                    placeholder=f"Feedback for {selected_asset}...",
                    className='form-control'
                ),
                html.Button(f'Submit Feedback for {selected_asset}', id='submit-feedback-' + asset, className='btn btn-primary mt-2'),
                html.Div(id='feedback-output-' + asset, className='mt-2')
            ]))
    return feedback_section

@app.callback(
    Output('feedback-output', 'children'),
    Input('submit-feedback', 'n_clicks'),
    State('feedback', 'value')
)
def submit_feedback(n_clicks, feedback_text):
    if n_clicks:
        # Here, you should implement code to store the general feedback
        # For simplicity, we just display the submitted general feedback
        return html.Div([
            html.H5('General Feedback:', className='mb-2'),
            html.P(feedback_text, className='alert alert-success')
        ])

@app.callback(
    Output('feedback-output-', 'children'),
    Input('submit-feedback-', 'n_clicks'),
    State('feedback-', 'value')
)
def submit_stock_feedback(n_clicks, feedback_text):
    if n_clicks:
        # Here, you should implement code to store feedback specific to each stock
        # For simplicity, we just display the submitted stock-specific feedback
        return html.Div([
            html.H5('Feedback Submitted:', className='mb-2'),
            html.P(feedback_text, className='alert alert-success')
        ])

if __name__ == '__main__':
    app.run_server(debug=True)
