def trades_between_dates(trading_data, start_date, end_date, security):
    """
    Returns the number of unique trade dates for the given security in the given time period.

    Parameters:
    trading_data (DataFrame): The DataFrame containing the trading data.
    start_date (str): The start date of the time period in 'YYYY-MM-DD' format.
    end_date (str): The end date of the time period in 'YYYY-MM-DD' format.
    security (str): The security identifier.

    Returns:
    int: The number of unique trade dates for the given security in the given time period.
    """
    return trading_data[
        (
            (trading_data["dateTimesent"] >= start_date)
            & (trading_data["dateTimesent"] <= end_date)
            & (trading_data["iliteInstrumentId"] == security)
        )
    ]["dateTimesent"].nunique()


