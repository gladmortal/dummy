import sqlite3
from dash import dcc, html, Input, Output

app = dash.Dash(__name__)

# Layout components including the button to load data
app.layout = html.Div([
    # ... (your existing layout components)

    # Button to load data from the database
    html.Button('Load Feedback Data', id='load-data-button', className='btn btn-primary mt-3'),

    # Div to display the loaded data
    html.Div(id='feedback-data-output', className='mt-3')
])

# Callback function to load data from the database and update the output div
@app.callback(
    Output('feedback-data-output', 'children'),
    Input('load-data-button', 'n_clicks')
)
def load_feedback_data(n_clicks):
    if n_clicks:
        # Connect to the SQLite database
        conn = sqlite3.connect('feedback.db')
        cursor = conn.cursor()

        # Execute a query to fetch data from the feedback table
        cursor.execute('SELECT * FROM feedback')

        # Fetch all rows from the result set
        feedback_data = cursor.fetchall()

        # Close the connection
        conn.close()

        # Create a table to display the fetched data
        table_data = []
        for row in feedback_data:
            table_data.append(html.Tr([html.Td(str(cell)) for cell in row]))

        # Create an HTML table with the fetched data
        feedback_table = html.Table([
            html.Thead([
                html.Tr([html.Th(col) for col in ['ID', 'Asset', 'Feedback', 'User', 'Submission Date']])
            ]),
            html.Tbody(table_data)
        ])

        return feedback_table

if __name__ == '__main__':
    app.run_server(debug=True)
